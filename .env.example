# =============================================
#   NOFAL PANEL - Environment Configuration
# =============================================

# Panel Settings
PANEL_NAME=Nofal Panel
PANEL_PORT=2083
PANEL_HOST=0.0.0.0
# IP العام للخادم (DNS A / إنشاء حسابات WHM — لا تستخدم 127.0.0.1 على الإنتاج)
PANEL_PUBLIC_IP=
SECRET_KEY=change-this-to-a-long-random-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Admin Credentials (Change immediately after install!)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=NofaLPanel@2024
ADMIN_EMAIL=admin@yourdomain.com

# Database (SQLite for panel data)
DATABASE_URL=sqlite:///./nofal_panel.db

# MySQL Server (for hosting databases)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_ROOT_USER=root
MYSQL_ROOT_PASSWORD=your_mysql_root_password

# Mail Server
MAIL_DOMAIN=mail.yourdomain.com
POSTFIX_CONFIG=/etc/postfix/main.cf
# Webmail (Roundcube / Rainloop) — لزر «فتح البريد» في cPanel Email
WEBMAIL_URL=
MAIL_IMAP_HOST=
MAIL_SMTP_HOST=
MAIL_IMAP_PORT=993
MAIL_SMTP_PORT=587
MAIL_SMTP_PORT_SSL=465

# Paths
NGINX_SITES_AVAILABLE=/etc/nginx/sites-available
NGINX_SITES_ENABLED=/etc/nginx/sites-enabled
BIND_ZONES_DIR=/etc/bind/zones
VSFTPD_USER_DIR=/etc/vsftpd/users
ACCOUNTS_HOME=/home

# SSL
CERTBOT_EMAIL=admin@yourdomain.com

# cPanel-style tools (optional)
PHPMYADMIN_URL=
NGINX_ACCESS_LOG=/var/log/nginx/access.log
NGINX_ERROR_LOG=/var/log/nginx/error.log
